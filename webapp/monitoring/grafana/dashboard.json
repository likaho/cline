{
  "dashboard": {
    "title": "Cline Microservices Overview",
    "tags": ["cline", "microservices"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 3,
        "title": "p99 Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{service}} p99"
          }
        ],
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"cline-.*\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}"
          }
        ],
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "container_memory_usage_bytes{pod=~\"cline-.*\"}",
            "legendFormat": "{{pod}}"
          }
        ],
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8}
      },
      {
        "id": 6,
        "title": "Active WebSocket Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "websocket_active_connections",
            "legendFormat": "Active"
          }
        ],
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8}
      },
      {
        "id": 7,
        "title": "AI Service Token Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(ai_tokens_used_total[1h])) by (model)",
            "legendFormat": "{{model}}"
          }
        ],
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8}
      },
      {
        "id": 8,
        "title": "Browser Pool Status",
        "type": "stat",
        "targets": [
          {
            "expr": "browser_service_available_browsers",
            "legendFormat": "Available"
          },
          {
            "expr": "browser_service_active_browsers",
            "legendFormat": "In Use"
          }
        ],
        "gridPos": {"x": 12, "y": 24, "w": 6, "h": 8}
      },
      {
        "id": 9,
        "title": "Task Queue Depth",
        "type": "stat",
        "targets": [
          {
            "expr": "task_queue_depth",
            "legendFormat": "Pending Tasks"
          }
        ],
        "gridPos": {"x": 18, "y": 24, "w": 6, "h": 8}
      }
    ]
  }
}
